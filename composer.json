{
  "name": "statington/statington",
  "description": "Drop-in local-first observability for PHP apps.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "observability",
    "debugging",
    "tracing",
    "logging",
    "sqlite",
    "php"
  ],
  "homepage": "https://github.com/trafficinc/statington",
  "support": {
    "issues": "https://github.com/trafficinc/statington/issues",
    "source": "https://github.com/trafficinc/statington"
  },
  "require": {
    "php": ">=8.1",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "suggest": {
    "ext-pdo_sqlite": "Required for the local collector storage.",
    "ext-curl": "Used by the SDK transport when available."
  },
  "autoload": {
    "psr-4": {
      "Statington\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Statington\\Tests\\": "tests/",
      "Demo\\": "demo/"
    }
  },
  "scripts": {
    "statington": "php -S localhost:8123 server/router.php",
    "demo": "php -S localhost:8080 demo/public/index.php",
    "test": "php tests/run.php",
    "test:unit": "phpunit"
  },
  "bin": [
    "bin/statington"
  ]
}
